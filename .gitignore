# ──────────────────────────────────────────────────────────
#  .gitignore  —  ExplainGrade / Explainable_Scoring
#  Keep: HTML, CSS, JS (frontend), vercel.json, package.json,
#        README.md, server.js
#  Exclude: Python backend, environments, private data, large files
#
#  IMPORTANT: Do NOT push api/ or backend_local/ to GitHub.
#  Vercel auto-detects any api/ folder as a Python serverless function
#  and tries to install ALL of requirements.txt (torch, spacy, pyspark
#  etc = 5.5 GB) — exceeding the 500 MB Lambda storage limit.
# ──────────────────────────────────────────────────────────

# ── Python Backend (local-only, NOT for Vercel) ──────────
# Vercel treats any api/ folder as serverless functions — keep off GitHub
api/
backend_local/

# ── Python Source / Scripts (local processing only) ──────
src/
local_grader.py
anchor_extraction.py
combine_analytics.py
model_training.py
semantic_mapping.py
test_grading.py
requirements.txt

# ── Python Environments ──────────────────────────────────
venv/
spacy-env/
env/
ENV/
.venv/

# ── Python Cache & Build ─────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/

# ── Node / JS ────────────────────────────────────────────
node_modules/
package-lock.json

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

