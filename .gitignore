# ──────────────────────────────────────────────────────────
#  .gitignore  —  ExplainGrade / Explainable_Scoring
#  Keep: HTML, CSS, JS (frontend), vercel.json, package.json,
#        requirements.txt, README.md, server.js, Python source
#  Exclude: environments, caches, private data, large files
# ──────────────────────────────────────────────────────────

# ── Python Environments ──────────────────────────────────
venv/
spacy-env/
env/
ENV/
.venv/

# ── Python Cache & Build ─────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/

# ── Node / JS ────────────────────────────────────────────
node_modules/
package-lock.json

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Environment / Secrets ────────────────────────────────
.env
.env.local
.env.*

# ── IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Large Binary / Compiled Files ────────────────────────
*.dll
*.so
*.pth
*.whl

# ── Trained ML Models (private / large) ─────────────────
*.pkl
*.joblib
*.h5
*.pt
*.pth
asag_scoring_model.pkl
feature_scaler.pkl

# ── Private / Sensitive Data Files ───────────────────────
