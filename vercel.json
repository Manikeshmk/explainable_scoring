{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "installCommand": "",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/pipeline", "destination": "/pipeline.html" },
    { "source": "/research", "destination": "/research.html" },
    { "source": "/usage", "destination": "/usage.html" },
    { "source": "/chat", "destination": "/chat.html" },
    { "source": "/analytics", "destination": "/analytics.html" },
    { "source": "/technologies", "destination": "/technologies.html" },
    { "source": "/test_results", "destination": "/test_results.html" },
    { "source": "/test-results", "destination": "/test_results.html" }
  ]
}
